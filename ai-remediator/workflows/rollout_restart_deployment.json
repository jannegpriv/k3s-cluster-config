        }
      }
    },
    {
      "id": "result",
      "name": "Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        -100
      ],
      "parameters": {
        "jsCode": "const r = $input.first().json;\nif (r.blocked) return [{json: {ok: false, tool: \"rollout_restart_deployment\", detail: r.detail}}];\nconst ok = r.statusCode < 400;\nconsole.log(JSON.stringify({audit: \"rollout_restart_deployment\", ts: new Date().toISOString(), status: r.statusCode, ok}));\nreturn [{json: {ok, tool: \"rollout_restart_deployment\", status: r.statusCode,\n  detail: ok ? \"executed (approved by operator)\" : `K8s API ${r.statusCode}: ${JSON.stringify(r.body?.message || r.body).slice(0,300)}`}}];"
      }
    },
    {
