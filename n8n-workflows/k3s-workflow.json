    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst alerts = body.alerts || [];\nconst messages = [];\n\nfor (const alert of alerts) {\n  const status = alert.status === 'firing' ? '\ud83d\udd25 FIRING' : '\u2705 RESOLVED';\n  const severity = alert.labels?.severity || 'unknown';\n  const alertname = alert.labels?.alertname || 'Unknown Alert';\n  const description = alert.annotations?.description || alert.annotations?.summary || 'No description';\n  \n  const emoji = severity === 'critical' ? '\ud83d\udea8' : severity === 'warning' ? '\u26a0\ufe0f' : '\u2139\ufe0f';\n  \n  messages.push({\n    text: `### ${emoji} ${status}: ${alertname}\\n**Severity:** ${severity}\\n**Description:** ${description}`\n  });\n}\n\nreturn messages.length > 0 ? messages : [{ text: 'No alerts received' }];"
      },
