    {
      "parameters": {
        "jsCode": "const cpuData = $('Get K3s CPU usage').first().json;\nconst memoryData = $('Get K3s memory usage').first().json;\nconst alertsData = $('Get K3s active alerts').first().json;\nconst eventsResponse = $('Get K3s Events').first().json;\n\nlet cpuInfo = \"CPU usage per node:\\n\";\nif (cpuData && cpuData.data && cpuData.data.result) {\n  cpuData.data.result.forEach(node => {\n    const instance = node.metric.instance.split(':')[0];\n    const usage = parseFloat(node.value[1]).toFixed(1);\n    cpuInfo += \"- \" + instance + \": \" + usage + \"%\\n\";\n  });\n} else {\n  cpuInfo += \"- Could not fetch CPU data\\n\";\n}\n\nlet memoryInfo = \"Memory usage per node:\\n\";\nif (memoryData && memoryData.data && memoryData.data.result) {\n  memoryData.data.result.forEach(node => {\n    const instance = node.metric.instance.split(':')[0];\n    const usage = parseFloat(node.value[1]).toFixed(1);\n    memoryInfo += \"- \" + instance + \": \" + usage + \"%\\n\";\n  });\n} else {\n  memoryInfo += \"- Could not fetch memory data\\n\";\n}\n\nlet alertsInfo = \"Active alerts:\\n\";\nif (Array.isArray(alertsData) && alertsData.length > 0) {\n  alertsData.forEach(alert => {\n    const name = alert.labels?.alertname || 'Unknown';\n    const severity = alert.labels?.severity || 'unknown';\n    const status = alert.status?.state || 'unknown';\n    alertsInfo += \"- [\" + severity.toUpperCase() + \"] \" + name + \" (\" + status + \")\\n\";\n  });\n} else {\n  alertsInfo += \"- No active alerts!\\n\";\n}\n\nlet eventsInfo = \"Recent Kubernetes Events (non-normal):\\n\";\nif (eventsResponse && eventsResponse.items && Array.isArray(eventsResponse.items)) {\n  const recentEvents = eventsResponse.items\n    .filter(e => e.type !== 'Normal' && e.lastTimestamp)\n    .sort((a, b) => new Date(b.lastTimestamp) - new Date(a.lastTimestamp))\n    .slice(0, 10);\n  \n  if (recentEvents.length > 0) {\n    recentEvents.forEach(event => {\n      const ns = event.metadata?.namespace || 'unknown';\n      const type = event.type || 'Unknown';\n      const reason = event.reason || 'Unknown';\n      const msg = (event.message || 'No message').substring(0, 100);\n      eventsInfo += \"- [\" + ns + \"] \" + type + \": \" + reason + \" - \" + msg + \"...\\n\";\n    });\n  } else {\n    eventsInfo += \"- No recent events\\n\";\n  }\n} else {\n  eventsInfo += \"- Could not fetch events (API may need RBAC permissions)\\n\";\n}\n\nconst report = \"K3s Cluster Status Report\\n==========================\\n\\n\" + cpuInfo + \"\\n\" + memoryInfo + \"\\n\" + alertsInfo + \"\\n\" + eventsInfo;\n\nreturn [{ json: { report: report } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
